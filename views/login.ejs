<%- include('partials/header') %>

<main class="flex-grow flex items-center justify-center bg-gray-50 dark:bg-gray-900 px-4 py-12">
    <div class="w-full max-w-md">
        <div class="bg-white dark:bg-gray-800 shadow-2xl rounded-2xl p-8">
            <h2 class="text-center text-3xl font-extrabold text-gray-900 dark:text-white mb-2">
                Acesse sua Conta
            </h2>
            <p class="text-center text-sm text-gray-600 dark:text-gray-400 mb-8">
                Ou <a href="#register-form" class="font-medium text-blue-600 hover:text-blue-500">crie uma nova conta</a>
            </p>

            <% if (erro) { %>
                <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 mb-6 rounded-md" role="alert">
                    <p><%= erro %></p>
                </div>
            <% } %>
            <% if (sucesso) { %>
                <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 mb-6 rounded-md" role="alert">
                    <p><%= sucesso %></p>
                </div>
            <% } %>

            <!-- Formulário de Login -->
            <form action="/login" method="POST" class="space-y-6">
                <div>
                    <label for="email-login" class="sr-only">Email</label>
                    <input id="email-login" name="email" type="email" required class="appearance-none rounded-md relative block w-full px-3 py-3 border border-gray-300 dark:border-gray-600 placeholder-gray-500 text-gray-900 dark:text-white bg-gray-50 dark:bg-gray-700 focus:outline-none focus:ring-blue-500 focus:border-blue-500 focus:z-10 sm:text-sm" placeholder="Seu e-mail">
                </div>
                <div class="relative">
                    <label for="senha-login" class="sr-only">Senha</label>
                    <input id="senha-login" name="senha" type="password" required class="appearance-none rounded-md relative block w-full px-3 py-3 border border-gray-300 dark:border-gray-600 placeholder-gray-500 text-gray-900 dark:text-white bg-gray-50 dark:bg-gray-700 focus:outline-none focus:ring-blue-500 focus:border-blue-500 focus:z-10 sm:text-sm" placeholder="Sua senha">
                    <button type="button" id="toggle-password-login" class="absolute inset-y-0 right-0 px-3 flex items-center text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200" aria-label="Mostrar senha">
                        <i class="fas fa-eye"></i>
                    </button>
                </div>
                <div>
                    <button type="submit" class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                        Entrar
                    </button>
                </div>
            </form>

            <div class="mt-6">
                <div class="relative">
                    <div class="absolute inset-0 flex items-center">
                        <div class="w-full border-t border-gray-300 dark:border-gray-600"></div>
                    </div>
                    <div class="relative flex justify-center text-sm">
                        <span class="px-2 bg-white dark:bg-gray-800 text-gray-500">
                            Ou continue com
                        </span>
                    </div>
                </div>
                <div class="mt-6">
                    <a href="/auth/google" class="w-full inline-flex justify-center py-3 px-4 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm bg-white dark:bg-gray-700 text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-600">
                        <img class="w-5 h-5" src="https://www.svgrepo.com/show/475656/google-color.svg" alt="Google logo">
                        <span class="ml-3">Login com Google</span>
                    </a>
                </div>
            </div>

            <!-- Formulário de Cadastro -->
            <div id="register-form" class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-700">
                <h3 class="text-center text-2xl font-bold text-gray-900 dark:text-white mb-6">
                    Criar Nova Conta
                </h3>
                <form action="/register" method="POST" class="space-y-6">
                    <div>
                        <label for="nome-register" class="sr-only">Nome</label>
                        <input id="nome-register" name="nome" type="text" required class="appearance-none rounded-md relative block w-full px-3 py-3 border border-gray-300 dark:border-gray-600 placeholder-gray-500 text-gray-900 dark:text-white bg-gray-50 dark:bg-gray-700 focus:outline-none focus:ring-blue-500 focus:border-blue-500 focus:z-10 sm:text-sm" placeholder="Seu nome completo">
                    </div>
                    <div>
                        <label for="email-register" class="sr-only">Email</label>
                        <input id="email-register" name="email" type="email" required class="appearance-none rounded-md relative block w-full px-3 py-3 border border-gray-300 dark:border-gray-600 placeholder-gray-500 text-gray-900 dark:text-white bg-gray-50 dark:bg-gray-700 focus:outline-none focus:ring-blue-500 focus:border-blue-500 focus:z-10 sm:text-sm" placeholder="Seu e-mail">
                    </div>
                    <div class="relative">
                        <label for="senha-register" class="sr-only">Senha</label>
                        <input id="senha-register" name="senha" type="password" required class="appearance-none rounded-md relative block w-full px-3 py-3 border border-gray-300 dark:border-gray-600 placeholder-gray-500 text-gray-900 dark:text-white bg-gray-50 dark:bg-gray-700 focus:outline-none focus:ring-blue-500 focus:border-blue-500 focus:z-10 sm:text-sm" placeholder="Crie uma senha">
                        <button type="button" id="toggle-password-register" class="absolute inset-y-0 right-0 px-3 flex items-center text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200" aria-label="Mostrar senha">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                    <div>
                        <button type="submit" class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
                            Cadastrar
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</main>

<%- include('partials/footer') %>