<%- include('partials/header') %>

<main class="container mx-auto px-4 py-8">
    <div class="bg-white dark:bg-gray-800 shadow-md rounded-lg p-6">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-4"><%= titulo %></h1>
        <p class="text-gray-600 dark:text-gray-300 mb-6">
            Aqui você pode gerenciar suas solicitações de serviço e contatos.
        </p>

        <!-- Tabela de Pedidos -->
        <div class="overflow-x-auto">
            <table class="min-w-full bg-white dark:bg-gray-800">
                <thead class="bg-gray-50 dark:bg-gray-700">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Serviço/Contato</th>
                        <% if (isAdmin) { %>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Usuário</th>
                        <% } %>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Data</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Status</th>
                        <% if (isAdmin) { %>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Ações</th>
                        <% } %>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                    <% if (pedidos.length > 0) { %>
                        <% pedidos.forEach(pedido => { %>
                            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm font-medium text-gray-900 dark:text-white"><%= pedido.servico %></div>
                                    <div class="text-sm text-gray-500 dark:text-gray-400 truncate" style="max-width: 250px;" title="<%= pedido.mensagem %>"><%= pedido.mensagem %></div>
                                </td>
                                <% if (isAdmin) { %>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="text-sm font-medium text-gray-900 dark:text-white"><%= pedido.nome %></div>
                                        <div class="text-sm text-gray-500 dark:text-gray-400"><%= pedido.email %></div>
                                    </td>
                                <% } %>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                                    <%= new Date(pedido.data_criacao).toLocaleDateString('pt-BR') %>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
                                        <%= pedido.status === 'Pendente' ? 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-300' : '' %>
                                        <%= pedido.status === 'Em Andamento' ? 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300' : '' %>
                                        <%= pedido.status === 'Concluído' ? 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300' : '' %>
                                    ">
                                        <%= pedido.status %>
                                    </span>
                                </td>
                                <% if (isAdmin) { %>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                                        <!-- Formulário de Status para Admin -->
                                        <form action="/admin/atualizar-status" method="POST" class="status-form">
                                            <input type="hidden" name="id" value="<%= pedido.id %>">
                                            <input type="hidden" name="tipo" value="<%= pedido.tipo %>">
                                            <select name="status" onchange="this.form.submit()" class="text-sm rounded-lg dark:bg-gray-700 dark:border-gray-600 dark:text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
                                                <option value="Pendente" <%= pedido.status === 'Pendente' ? 'selected' : '' %>>Pendente</option>
                                                <option value="Em Andamento" <%= pedido.status === 'Em Andamento' ? 'selected' : '' %>>Em Andamento</option>
                                                <option value="Concluído" <%= pedido.status === 'Concluído' ? 'selected' : '' %>>Concluído</option>
                                            </select>
                                        </form>
                                    </td>
                                <% } %>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="<%= isAdmin ? '5' : '3' %>" class="px-6 py-12 text-center text-gray-500 dark:text-gray-400">
                                Nenhuma solicitação encontrada.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</main>

<%- include('partials/footer') %>