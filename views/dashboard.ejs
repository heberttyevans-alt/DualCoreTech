<%- include('partials/header') %>

<main class="container mx-auto px-4 py-8">
    <div class="bg-white dark:bg-gray-800 shadow-md rounded-lg p-6">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-4"><%= titulo %></h1>
        <p class="text-gray-600 dark:text-gray-300 mb-6">
            Aqui você pode gerenciar suas solicitações de serviço e contatos.
        </p>

        <!-- Formulário de Busca e Filtro -->
        <form action="/dashboard" method="GET" class="mb-8 p-4 bg-gray-100 dark:bg-gray-700 rounded-lg shadow-md flex flex-col sm:flex-row gap-4 items-center">
            <div class="flex-grow w-full sm:w-auto">
                <label for="busca" class="sr-only">Buscar</label>
                <input type="text" name="busca" id="busca" placeholder="Buscar por serviço, mensagem..." value="<%= locals.filtroBusca || '' %>" class="w-full px-4 py-2 border border-gray-300 rounded-lg dark:bg-gray-800 dark:border-gray-600 focus:outline-none focus:ring-2 focus:ring-emerald-500">
            </div>
            <div class="w-full sm:w-auto">
                <label for="status" class="sr-only">Filtrar por status</label>
                <select name="status" id="status" onchange="this.form.submit()" class="w-full px-4 py-2 border border-gray-300 rounded-lg dark:bg-gray-800 dark:border-gray-600 focus:outline-none focus:ring-2 focus:ring-emerald-500">
                    <option value="">Todos os Status</option>
                    <option value="Pendente" <%= (locals.filtroStatus === 'Pendente') ? 'selected' : '' %>>Pendente</option>
                    <option value="Em Andamento" <%= (locals.filtroStatus === 'Em Andamento') ? 'selected' : '' %>>Em Andamento</option>
                    <option value="Concluído" <%= (locals.filtroStatus === 'Concluído') ? 'selected' : '' %>>Concluído</option>
                </select>
            </div>
            <div class="flex gap-2">
                <button type="submit" class="px-6 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-opacity-50">Filtrar</button>
                <a href="/dashboard" class="px-6 py-2 bg-gray-500 text-white rounded-lg hover:bg-gray-600">Limpar</a>
            </div>
        </form>

        <!-- Tabela de Pedidos -->
        <div class="overflow-x-auto">
            <table class="min-w-full bg-white dark:bg-gray-800">
                <thead class="bg-gray-50 dark:bg-gray-700">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Serviço/Contato</th>
                        <% if (isAdmin) { %>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Usuário</th>
                        <% } %>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Data</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Status</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Ações</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                    <% if (pedidos.length > 0) { %>
                        <% pedidos.forEach(pedido => { %>
                            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm font-medium text-gray-900 dark:text-white"><%= pedido.servico %></div>
                                    <div class="text-sm text-gray-500 dark:text-gray-400 truncate" style="max-width: 250px;" title="<%= pedido.mensagem %>"><%= pedido.mensagem %></div>
                                </td>
                                <% if (isAdmin) { %>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="text-sm font-medium text-gray-900 dark:text-white"><%= pedido.nome %></div>
                                        <div class="text-sm text-gray-500 dark:text-gray-400"><%= pedido.email %></div>
                                        <% if (pedido.telefone) { %>
                                            <div class="text-sm text-gray-500 dark:text-gray-400"><i class="fas fa-phone-alt mr-1"></i><%= pedido.telefone %></div>
                                        <% } %>
                                    </td>
                                <% } %>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                                    <%= new Date(pedido.data_criacao).toLocaleDateString('pt-BR') %>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
                                        <%= pedido.status === 'Pendente' ? 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-300' : '' %>
                                        <%= pedido.status === 'Em Andamento' ? 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300' : '' %>
                                        <%= pedido.status === 'Concluído' ? 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300' : '' %>
                                    ">
                                        <%= pedido.status %>
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                                    <% if (isAdmin) { %>
                                        <div class="flex items-center gap-4">
                                            <!-- Formulário de Status para Admin -->
                                            <form action="/admin/atualizar-status" method="POST" class="status-form">
                                                <input type="hidden" name="id" value="<%= pedido.id %>">
                                                <input type="hidden" name="tipo" value="<%= pedido.tipo %>">
                                                <select name="status" onchange="this.form.submit()" class="text-sm rounded-lg border-gray-300 dark:bg-gray-700 dark:border-gray-600 dark:text-white focus:outline-none focus:ring-1 focus:ring-emerald-500">
                                                    <option value="Pendente" <%= pedido.status === 'Pendente' ? 'selected' : '' %>>Pendente</option>
                                                    <option value="Em Andamento" <%= pedido.status === 'Em Andamento' ? 'selected' : '' %>>Em Andamento</option>
                                                    <option value="Concluído" <%= pedido.status === 'Concluído' ? 'selected' : '' %>>Concluído</option>
                                                </select>
                                            </form>
                                            <!-- Formulário de Exclusão para Admin -->
                                            <form action="/admin/excluir-solicitacao" method="POST" onsubmit="return confirm('Tem certeza que deseja excluir esta solicitação? Esta ação não pode ser desfeita.');">
                                                <input type="hidden" name="id" value="<%= pedido.id %>">
                                                <input type="hidden" name="tipo" value="<%= pedido.tipo %>">
                                                <button type="submit" class="text-red-500 hover:text-red-700 dark:text-red-400 dark:hover:text-red-500" title="Excluir Solicitação">
                                                    <i class="fas fa-trash-alt fa-lg"></i>
                                                </button>
                                            </form>
                                        </div>
                                    <% } else { %>
                                        <!-- Formulário de Exclusão para Usuário (botão desabilita se não estiver pendente) -->
                                        <form action="/dashboard/excluir-solicitacao" method="POST" onsubmit="return confirm('Tem certeza que deseja excluir esta solicitação?');">
                                            <input type="hidden" name="id" value="<%= pedido.id %>">
                                            <input type="hidden" name="tipo" value="<%= pedido.tipo %>">
                                            <button type="submit" class="text-red-500 hover:text-red-700 dark:text-red-400 dark:hover:text-red-500 disabled:opacity-50 disabled:cursor-not-allowed"
                                                    title="<%= pedido.status === 'Pendente' ? 'Excluir Solicitação' : 'Só é possível excluir solicitações pendentes.' %>"
                                                    <%- pedido.status !== 'Pendente' ? 'disabled' : '' %>>
                                                <i class="fas fa-trash-alt fa-lg"></i>
                                            </button>
                                        </form>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="<%= isAdmin ? '5' : '4' %>" class="px-6 py-12 text-center text-gray-500 dark:text-gray-400">
                                Nenhuma solicitação encontrada.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</main>

<%- include('partials/footer') %>