    flex justify-between items-center gap-6">
    <span class="inline-flex items-center">
        <img src="/images/logoDualCoreTech.png"
             alt="Logo DualCore Tech"
             class="h-12 w-auto object-contain">
    </span>
        <a href="/home" class="text-gray-300
        hover:bg-gray-700 hover:text-white transition-colors">Home</a>
        <a href="/contatos" class="text-gray-300
        hover:bg-gray-700 hover:text-white transition-colors">Fale Conosco</a>
        <a href="/sobre" class="text-gray-300
        hover:bg-gray-700 hover:text-white transition-colors">Quem somos</a>
    </nav>
