<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class'
        };
    </script>
    <link rel="icon" href="/images/logoGuia.png" type="image/png">
    <script>
        if (
            localStorage.getItem('color-theme') === 'dark' ||
            (!('color-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)
        ) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>
    <title>
        <%= titulo || 'Dual Core Tech' %>
    </title>
</head>

<body class="min-h-screen bg-gray-50 text-gray-900 dark:bg-gray-900 dark:text-gray-100 flex flex-col transition-colors duration-200">
    <nav class="px-6 py-3 md:px-8 md:py-4 flex justify-between items-center gap-3 md:gap-4 rounded-none shadow-sm bg-gradient-to-r from-emerald-700 via-green-600 to-sky-700 dark:from-emerald-950 dark:via-green-900 dark:to-sky-950 border-b border-emerald-500/20 dark:border-sky-700/30">
        <span class="inline-flex items-center shrink-0">
            <img src="/images/logoDualCoreTech.png"
                 alt="Logo DualCore Tech"
                 class="h-12 w-auto object-contain">
        </span>
        <div class="flex items-center gap-2 md:gap-3">
            <a href="/home" class="inline-flex items-center justify-center whitespace-nowrap px-4 py-2 md:px-5 md:py-2.5 text-sm md:text-base font-medium text-white rounded-xl bg-white/10 hover:bg-white/15 dark:bg-white/5 dark:hover:bg-white/10 transition-colors duration-200">Home</a>            
            <a href="/sobre" class="inline-flex items-center justify-center whitespace-nowrap px-4 py-2 md:px-5 md:py-2.5 text-sm md:text-base font-medium text-white rounded-xl bg-white/10 hover:bg-white/15 dark:bg-white/5 dark:hover:bg-white/10 transition-colors duration-200">Quem somos</a>
            <a href="/servicos" class="inline-flex items-center justify-center whitespace-nowrap px-4 py-2 md:px-5 md:py-2.5 text-sm md:text-base font-medium text-white rounded-xl bg-white/10 hover:bg-white/15 dark:bg-white/5 dark:hover:bg-white/10 transition-colors duration-200">Serviços</a>
            <a href="/contatos" class="inline-flex items-center justify-center whitespace-nowrap px-4 py-2 md:px-5 md:py-2.5 text-sm md:text-base font-medium text-white rounded-xl bg-white/10 hover:bg-white/15 dark:bg-white/5 dark:hover:bg-white/10 transition-colors duration-200">Fale Conosco</a>
        </div>
    </nav>
