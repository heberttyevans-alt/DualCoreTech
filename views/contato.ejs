<%-include('partials/header') %>
<section class="px-4 py-8 sm:px-6 sm:py-16 md:py-24">
    <div class="mx-auto max-w-4xl overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-lg dark:border-slate-700 dark:bg-slate-800">
        <div class="bg-gradient-to-r from-emerald-600 to-teal-500 px-4 py-5 sm:px-8 sm:py-6">
            <h1 class="text-2xl font-bold text-white sm:text-3xl">Fale conosco</h1>
            <p class="mt-1 text-sm text-emerald-50 sm:mt-2 sm:text-base">
                Entre em contato para tirar dúvidas, solicitar um orçamento ou saber mais sobre nossos serviços.
            </p>
        </div>
        <form action="/contatos" method="POST" class="space-y-4 p-4 sm:space-y-5 sm:p-8">
            <% if (typeof erro !== 'undefined' && erro) { %>
                <div class="rounded-xl border border-red-300 bg-red-50 px-4 py-3 text-sm text-red-700 dark:border-red-500/40 dark:bg-red-900/30 dark:text-red-100">
                    <%= erro %>
                </div>
            <% } %>
            <div>
                <label for="nome" class="block text-sm font-medium text-slate-700 dark:text-slate-200">Nome:</label>
                <input type="text" id="nome" name="nome" value="<%= dados && dados.nome ? dados.nome : '' %>" required class="mt-1 w-full rounded-xl border border-slate-300 bg-slate-50 px-3 py-2.5 text-sm outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-100 sm:px-4 sm:py-3 sm:text-base">
            </div>
            <div>
                <label for="email" class="block text-sm font-medium text-slate-700 dark:text-slate-200">Email:</label>
                <input type="email" id="email" name="email" value="<%= dados && dados.email ? dados.email : '' %>" required class="mt-1 w-full rounded-xl border border-slate-300 bg-slate-50 px-3 py-2.5 text-sm outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-100 sm:px-4 sm:py-3 sm:text-base">
            </div>
            <div>
                <label for="mensagem" class="block text-sm font-medium text-slate-700 dark:text-slate-200">Mensagem:</label>
                <textarea id="mensagem" name="mensagem" rows="5" required class="mt-1 w-full rounded-xl border border-slate-300 bg-slate-50 px-3 py-2.5 text-sm outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-100 sm:px-4 sm:py-3 sm:text-base"><%= dados && dados.mensagem ? dados.mensagem : '' %></textarea>
            </div>
            <div class="flex flex-col gap-3 sm:flex-row">
                <button type="submit" class="w-full rounded-xl bg-emerald-600 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-emerald-700 sm:w-auto sm:text-base">
                    Enviar
                </button>
                <a href="https://wa.me/5535991418078" target="_blank" rel="noopener noreferrer" class="inline-flex w-full items-center justify-center rounded-xl bg-green-500 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-green-600 sm:w-auto sm:text-base">
                    WhatsApp
                </a>
            </div>
        </form>
    </div>
</section>
<%-include('partials/footer') %>